<div class="page-header">
  <h2>编辑作品</h2>
  <a href="/works" class="btn btn-outline">返回列表</a>
</div>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>
<% if (work) { %>
<form action="/works/<%= work.id %>/edit" method="POST" class="form-card">
  <div class="form-group">
    <label for="title">作品名称 <span class="required">*</span></label>
    <input type="text" id="title" name="title" value="<%= work.title %>" required>
  </div>
  <div class="form-group">
    <label for="type">作品类型 <span class="required">*</span></label>
    <select id="type" name="type" required>
      <option value="稿件" <%= work.type === '稿件' ? 'selected' : '' %>>稿件</option>
      <option value="插画" <%= work.type === '插画' ? 'selected' : '' %>>插画</option>
      <option value="影音" <%= work.type === '影音' ? 'selected' : '' %>>影音</option>
    </select>
  </div>
  <div class="form-group">
    <label for="description">作品描述</label>
    <textarea id="description" name="description" rows="4"><%= work.description || '' %></textarea>
  </div>
  <div class="form-group">
    <label for="status">状态</label>
    <select id="status" name="status">
      <option value="草稿" <%= work.status === '草稿' ? 'selected' : '' %>>草稿</option>
      <option value="已登记" <%= work.status === '已登记' ? 'selected' : '' %>>已登记</option>
      <option value="已确权" <%= work.status === '已确权' ? 'selected' : '' %>>已确权</option>
      <option value="已驳回" <%= work.status === '已驳回' ? 'selected' : '' %>>已驳回</option>
    </select>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">保存</button>
    <a href="/works/<%= work.id %>" class="btn btn-outline">取消</a>
  </div>
</form>
<% } %>
