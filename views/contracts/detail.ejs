<div class="page-header">
  <h2>合同详情</h2>
  <a href="/contracts" class="btn btn-outline">返回列表</a>
</div>
<% if (contract) { %>
<div class="detail-card">
  <div class="detail-row">
    <span class="detail-label">合同ID</span>
    <span class="detail-value"><%= contract.id %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">作品名称</span>
    <span class="detail-value"><%= contract.work_title || '-' %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">作品类型</span>
    <span class="detail-value"><span class="badge badge-type"><%= contract.work_type || '-' %></span></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">被授权方</span>
    <span class="detail-value"><%= contract.licensee %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">合同类型</span>
    <span class="detail-value"><%= contract.contract_type %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">作者分成比例</span>
    <span class="detail-value"><%= (contract.revenue_share * 100).toFixed(0) %>%</span>
  </div>
  <div class="detail-row">
    <span class="detail-label">开始日期</span>
    <span class="detail-value"><%= contract.start_date %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">结束日期</span>
    <span class="detail-value"><%= contract.end_date %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">状态</span>
    <span class="detail-value"><span class="badge badge-status badge-<%= contract.status %>"><%= contract.status %></span></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">创建时间</span>
    <span class="detail-value"><%= contract.created_at %></span>
  </div>
  <div class="detail-actions">
    <% if (contract.status === '草稿') { %>
      <form action="/contracts/<%= contract.id %>/activate" method="POST" style="display:inline">
        <button type="submit" class="btn btn-success">激活合同</button>
      </form>
    <% } else if (contract.status === '生效中') { %>
      <form action="/contracts/<%= contract.id %>/terminate" method="POST" style="display:inline" onsubmit="return confirm('确定要终止此合同吗？')">
        <button type="submit" class="btn btn-danger">终止合同</button>
      </form>
    <% } %>
  </div>
</div>
<% } else { %>
<div class="alert alert-error"><%= error || '合同不存在' %></div>
<% } %>
