<div class="page-header">
  <h2>创建合同</h2>
  <a href="/contracts" class="btn btn-outline">返回列表</a>
</div>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>
<form action="/contracts/create" method="POST" class="form-card">
  <div class="form-group">
    <label for="work_id">选择作品 <span class="required">*</span></label>
    <select id="work_id" name="work_id" required>
      <option value="">-- 请选择作品 --</option>
      <% if (works && works.length > 0) { %>
        <% works.forEach(function(w) { %>
          <option value="<%= w.id %>"><%= w.title %> (<%= w.type %>)</option>
        <% }); %>
      <% } %>
    </select>
  </div>
  <div class="form-group">
    <label for="licensee">被授权方 <span class="required">*</span></label>
    <input type="text" id="licensee" name="licensee" required placeholder="请输入被授权方名称">
  </div>
  <div class="form-group">
    <label for="contract_type">合同类型 <span class="required">*</span></label>
    <select id="contract_type" name="contract_type" required>
      <option value="独家授权">独家授权</option>
      <option value="非独家授权">非独家授权</option>
      <option value="出版授权">出版授权</option>
      <option value="音频授权">音频授权</option>
      <option value="视频授权">视频授权</option>
      <option value="海外发行">海外发行</option>
      <option value="图库授权">图库授权</option>
    </select>
  </div>
  <div class="form-group">
    <label for="start_date">开始日期 <span class="required">*</span></label>
    <input type="date" id="start_date" name="start_date" required>
  </div>
  <div class="form-group">
    <label for="end_date">结束日期 <span class="required">*</span></label>
    <input type="date" id="end_date" name="end_date" required>
  </div>
  <div class="form-group">
    <label for="revenue_share">作者分成比例 <span class="required">*</span></label>
    <input type="number" id="revenue_share" name="revenue_share" step="0.01" min="0" max="1" value="0.5" required>
    <p class="form-hint">请输入0到1之间的小数，如0.5表示50%</p>
  </div>
  <div class="form-group">
    <label for="status">状态</label>
    <select id="status" name="status">
      <option value="草稿">草稿</option>
      <option value="生效中">生效中</option>
    </select>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">创建合同</button>
    <a href="/contracts" class="btn btn-outline">取消</a>
  </div>
</form>
