<div class="page-header">
  <h2>新增作品</h2>
  <a href="/works" class="btn btn-outline">返回列表</a>
</div>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>
<form action="/works/create" method="POST" class="form-card">
  <div class="form-group">
    <label for="title">作品名称 <span class="required">*</span></label>
    <input type="text" id="title" name="title" required placeholder="请输入作品名称">
  </div>
  <div class="form-group">
    <label for="type">作品类型 <span class="required">*</span></label>
    <select id="type" name="type" required>
      <option value="稿件">稿件</option>
      <option value="插画">插画</option>
      <option value="影音">影音</option>
    </select>
  </div>
  <div class="form-group">
    <label for="description">作品描述</label>
    <textarea id="description" name="description" rows="4" placeholder="请输入作品描述"></textarea>
  </div>
  <div class="form-group">
    <label for="status">状态</label>
    <select id="status" name="status">
      <option value="草稿">草稿</option>
      <option value="已登记">已登记</option>
    </select>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">提交</button>
    <a href="/works" class="btn btn-outline">取消</a>
  </div>
</form>
